# ─────────────────────────────────────────────────────────────
# Shiv Furniture House — React Client Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# In production, set these as Vercel Environment Variables
# (do NOT commit .env to git).
#
# All variables MUST be prefixed with VITE_ to be exposed to
# the browser by Vite. Never put secrets here.
# ─────────────────────────────────────────────────────────────

# ── Backend API base URL ──────────────────────────────────────
# Local dev:
VITE_API_URL=http://localhost:3000
# Production (your Vercel server URL, no trailing slash):
# VITE_API_URL=https://your-server.vercel.app

# ── UPI Payment ───────────────────────────────────────────────
VITE_UPI_ID=yourupi@bank
VITE_MERCHANT_NAME=Shiv%20Furniture%20House

# ── Google Sign-In ────────────────────────────────────────────
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com
# Authorised origins must include your Vercel client URL.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

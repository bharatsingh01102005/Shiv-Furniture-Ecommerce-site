# Normalize line endings for all text files
* text=auto

# Force LF for source files (important for cross-platform teams)
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.env.example text eol=lf
*.gitignore   text eol=lf
